{
  "name": "greensales-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "db:start": "docker compose up -d",
    "db:stop": "docker compose down",
    "backend": "cd backend && npm run dev",
    "frontend": "cd frontend && npm run dev",
    "dev:all": "concurrently \"npm run db:start\" \"npm run backend\" \"npm run frontend\""
  },
  "devDependencies": {
    "concurrently": "^9.2.3"
  }
}
